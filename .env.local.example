# Contact form (Gmail SMTP via nodemailer)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Admin panel (required)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Vercel Blob (recommended for production image/video uploads)
# Add the Blob integration in your Vercel project settings to get this token.
BLOB_READ_WRITE_TOKEN=

# Upstash Redis via Vercel Marketplace (recommended for production content storage)
# Add a Redis integration in your Vercel project settings to get these.
KV_REST_API_URL=
KV_REST_API_TOKEN=
